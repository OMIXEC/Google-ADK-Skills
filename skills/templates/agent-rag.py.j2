# src/agent.py
"""{{ agent_name }} - RAG-Enabled Agent

{{ description }}

RAG Configuration:
- Corpus: {{ rag_corpus_name }}
- Top K: {{ rag_top_k|default(10) }}
- Threshold: {{ rag_threshold|default(0.3) }}

Generated by Claude ADK Skills
"""

from google.adk.agents import Agent
from google.adk.tools import FunctionTool
from google.adk.tools.retrieval.vertex_ai_rag_retrieval import VertexAiRagRetrieval
from vertexai import rag
from config import RAG_CORPUS_NAME
{% if additional_tools %}
from tools.domain_tools import {{ additional_tools|join(', ') }}
{% endif %}

instruction = """
You are {{ persona_description }}.

**Role:** {{ role }}

**Knowledge Source:** You have access to a comprehensive knowledge base via RAG retrieval.

**Behavior Guidelines:**
{% for guideline in behavior_guidelines %}
{{ loop.index }}. {{ guideline }}
{% endfor %}

**RAG Usage Protocol:**
1. **Always search the knowledge base first** before answering questions
2. Cite specific sections or documents when providing information
3. If information is not in the knowledge base, clearly state this
4. Provide direct answers followed by supporting details from the knowledge base
5. Suggest related topics that might be helpful

**Response Format:**
- Direct answer to the question
- Supporting evidence from knowledge base (with citations)
- Related resources or topics (if relevant)
- Next steps or suggestions

{% if domain_specific_instructions %}
**Domain-Specific Instructions:**
{{ domain_specific_instructions }}
{% endif %}
"""

{{ agent_name }} = Agent(
    name="{{ agent_name }}",
    model="{{ model|default('gemini-2.5-flash') }}",
    description="{{ description }}",
    instruction=instruction,
    tools=[
        VertexAiRagRetrieval(
            name="search_knowledge",
            description="Search the knowledge base for relevant information",
            rag_resources=[
                rag.RagResource(rag_corpus=RAG_CORPUS_NAME)
            ],
            similarity_top_k={{ rag_top_k|default(10) }},
            vector_distance_threshold={{ rag_threshold|default(0.3) }},
        ),
        {% if additional_tools %}
        {% for tool in additional_tools %}
        FunctionTool({{ tool }}),
        {% endfor %}
        {% endif %}
    ],
)

# Export as root agent
root_agent = {{ agent_name }}


# RAG Corpus Setup (separate file: src/rag/corpus_setup.py)
"""
from vertexai import rag
import vertexai

# Initialize Vertex AI
vertexai.init(project="{{ gcp_project }}", location="{{ gcp_region|default('us-central1') }}")

# Create RAG corpus
def create_corpus():
    corpus = rag.create_corpus(
        display_name="{{ rag_display_name }}",
        description="{{ rag_description }}",
    )
    print(f"Corpus created: {corpus.name}")
    return corpus

# Ingest documents
def ingest_documents(corpus_name: str, source_path: str):
    # Import files from GCS
    response = rag.import_files(
        corpus_name=corpus_name,
        paths=[source_path],  # gs://bucket/path or local path
        chunk_size={{ chunk_size|default(512) }},
        chunk_overlap={{ chunk_overlap|default(50) }},
    )
    print(f"Imported files: {response}")

# Usage:
# corpus = create_corpus()
# ingest_documents(corpus.name, "gs://my-bucket/docs/")
"""
