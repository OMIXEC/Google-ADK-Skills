# Dockerfile for {{ agent_name }}
# Generated by Claude ADK Skills

FROM python:{{ python_version|default('3.11') }}-slim

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements file
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Copy application source code
COPY src/ ./src/
{% if config_files %}
COPY {{ config_files|join(' ') }} ./
{% endif %}

# Set environment variables
ENV PYTHONPATH=/app
ENV PORT={{ port|default(8080) }}
ENV PYTHONUNBUFFERED=1

{% if environment_variables %}
# Additional environment variables
{% for key, value in environment_variables.items() %}
ENV {{ key }}={{ value }}
{% endfor %}
{% endif %}

# Expose port
EXPOSE {{ port|default(8080) }}

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import requests; requests.get('http://localhost:{{ port|default(8080) }}/health')"

# Run the application
{% if use_gunicorn %}
CMD ["gunicorn", "src.main:app", \
     "--bind", "0.0.0.0:{{ port|default(8080) }}", \
     "--workers", "{{ workers|default(4) }}", \
     "--worker-class", "uvicorn.workers.UvicornWorker", \
     "--timeout", "{{ timeout|default(300) }}"]
{% else %}
CMD ["uvicorn", "src.main:app", \
     "--host", "0.0.0.0", \
     "--port", "{{ port|default(8080) }}", \
     "--workers", "{{ workers|default(1) }}"]
{% endif %}

# Optional: Non-root user for security
{% if use_nonroot_user %}
RUN useradd -m -u 1000 appuser && \
    chown -R appuser:appuser /app
USER appuser
{% endif %}
