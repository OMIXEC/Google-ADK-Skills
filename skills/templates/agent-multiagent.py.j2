# src/agent.py
"""{{ coordinator_name }} - Multi-Agent System

{{ description }}

Architecture: {{ pattern }}
Specialists: {{ specialists|join(', ') }}

Generated by Claude ADK Skills
"""

from google.adk.agents import Agent{% if pattern == 'sequential' %}, SequentialAgent{% endif %}

from google.adk.tools import FunctionTool
from google.adk.tools.agent_tool import AgentTool
{% if specialist_tools %}
from tools.domain_tools import {{ specialist_tools|join(', ') }}
{% endif %}

{% for specialist in specialists %}
# Specialist: {{ specialist.name }}
{{ specialist.name }} = Agent(
    name="{{ specialist.name }}",
    model="{{ specialist.model|default('gemini-2.5-flash') }}",
    description="{{ specialist.description }}",
    instruction="""
    You are {{ specialist.role }}.

    **Responsibilities:**
    {% for responsibility in specialist.responsibilities %}
    - {{ responsibility }}
    {% endfor %}

    **Behavior:**
    {{ specialist.behavior }}

    {% if specialist.tools %}
    **Tools:**
    {% for tool in specialist.tools %}
    - {{ tool }}
    {% endfor %}
    {% endif %}
    """,
    {% if specialist.tools %}
    tools=[
        {% for tool in specialist.tools %}
        FunctionTool({{ tool }}),
        {% endfor %}
    ],
    {% endif %}
)

{% endfor %}
{% if pattern == 'supervisor' %}
# Coordinator Agent
{{ coordinator_name }} = Agent(
    name="{{ coordinator_name }}",
    model="{{ coordinator_model|default('gemini-2.5-flash') }}",
    description="{{ description }}",
    instruction="""
    You are a coordinator managing a team of specialist agents.

    **Team Members:**
    {% for specialist in specialists %}
    - {{ specialist.name }}: {{ specialist.description }}
    {% endfor %}

    **Delegation Strategy:**
    {% for specialist in specialists %}
    - {{ specialist.delegation_condition }} → {{ specialist.name }}
    {% endfor %}

    **Workflow:**
    1. Analyze user request for required capabilities
    2. Delegate to appropriate specialist(s)
    3. Coordinate results if multiple specialists used
    4. Synthesize final response

    For simple queries you can handle directly, answer without delegation.
    """,
    tools=[
        {% for specialist in specialists %}
        AgentTool(agent={{ specialist.name }}),
        {% endfor %}
    ],
)

# Export coordinator as root agent
root_agent = {{ coordinator_name }}

{% elif pattern == 'sequential' %}
# Sequential Pipeline
pipeline = SequentialAgent(
    agents=[
        {% for specialist in specialists %}
        {{ specialist.name }},
        {% endfor %}
    ],
    name="{{ coordinator_name }}",
)

# Export pipeline as root agent
root_agent = pipeline

{% elif pattern == 'parallel' %}
# Parallel Execution Coordinator
{{ coordinator_name }} = Agent(
    name="{{ coordinator_name }}",
    model="{{ coordinator_model|default('gemini-2.5-flash') }}",
    description="{{ description }}",
    instruction="""
    You coordinate parallel execution of specialist agents.

    **Specialists:**
    {% for specialist in specialists %}
    - {{ specialist.name }}: {{ specialist.description }}
    {% endfor %}

    **Execution Strategy:**
    1. Determine which specialists can work in parallel
    2. Delegate tasks to all relevant specialists simultaneously
    3. Aggregate results as they complete
    4. Synthesize combined response

    Always run independent tasks in parallel for efficiency.
    """,
    tools=[
        {% for specialist in specialists %}
        AgentTool(agent={{ specialist.name }}),
        {% endfor %}
    ],
)

# Export coordinator as root agent
root_agent = {{ coordinator_name }}

{% endif %}
