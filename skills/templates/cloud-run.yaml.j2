# Cloud Run Service Configuration for {{ agent_name }}
# Generated by Claude ADK Skills

apiVersion: serving.knative.dev/v1
kind: Service
metadata:
  name: {{ service_name|default(agent_name|lower|replace('_', '-')) }}
  labels:
    app: {{ agent_name|lower|replace('_', '-') }}
    environment: {{ environment|default('production') }}
    managed-by: claude-adk-skills
  annotations:
    run.googleapis.com/launch-stage: {{ launch_stage|default('BETA') }}
spec:
  template:
    metadata:
      annotations:
        # Autoscaling
        autoscaling.knative.dev/minScale: "{{ min_instances|default(0) }}"
        autoscaling.knative.dev/maxScale: "{{ max_instances|default(10) }}"
        autoscaling.knative.dev/target: "{{ target_concurrency|default(80) }}"

        # Execution environment
        run.googleapis.com/execution-environment: {{ execution_env|default('gen2') }}

        {% if vpc_connector %}
        # VPC
        run.googleapis.com/vpc-access-connector: {{ vpc_connector }}
        run.googleapis.com/vpc-access-egress: {{ vpc_egress|default('private-ranges-only') }}
        {% endif %}

        {% if startup_cpu_boost %}
        # Startup CPU boost
        run.googleapis.com/startup-cpu-boost: "true"
        {% endif %}

      labels:
        app: {{ agent_name|lower|replace('_', '-') }}
        version: {{ version|default('v1') }}

    spec:
      # Container concurrency
      containerConcurrency: {{ container_concurrency|default(80) }}

      # Request timeout
      timeoutSeconds: {{ timeout_seconds|default(300) }}

      {% if service_account %}
      # Service account
      serviceAccountName: {{ service_account }}
      {% endif %}

      containers:
        - name: {{ agent_name|lower|replace('_', '-') }}
          image: {{ image|default('gcr.io/' + gcp_project + '/' + agent_name|lower|replace('_', '-') + ':latest') }}

          ports:
            - name: http1
              containerPort: {{ port|default(8080) }}

          # Environment variables
          env:
            - name: ENVIRONMENT
              value: "{{ environment|default('production') }}"

            - name: PORT
              value: "{{ port|default(8080) }}"

            {% if google_api_key_secret %}
            # Google API Key from Secret Manager
            - name: GOOGLE_API_KEY
              valueFrom:
                secretKeyRef:
                  name: {{ google_api_key_secret }}
                  key: latest
            {% endif %}

            {% if rag_corpus_name %}
            # RAG Configuration
            - name: RAG_CORPUS_NAME
              value: "{{ rag_corpus_name }}"
            {% endif %}

            {% if additional_env_vars %}
            # Additional environment variables
            {% for key, value in additional_env_vars.items() %}
            - name: {{ key }}
              value: "{{ value }}"
            {% endfor %}
            {% endif %}

            {% if additional_secrets %}
            # Additional secrets
            {% for key, secret in additional_secrets.items() %}
            - name: {{ key }}
              valueFrom:
                secretKeyRef:
                  name: {{ secret }}
                  key: latest
            {% endfor %}
            {% endif %}

          # Resource limits
          resources:
            limits:
              memory: "{{ memory|default('2Gi') }}"
              cpu: "{{ cpu|default('2') }}"

          # Health checks
          livenessProbe:
            httpGet:
              path: {{ liveness_path|default('/health') }}
              port: {{ port|default(8080) }}
            initialDelaySeconds: {{ liveness_initial_delay|default(30) }}
            periodSeconds: {{ liveness_period|default(10) }}
            timeoutSeconds: {{ liveness_timeout|default(5) }}
            failureThreshold: {{ liveness_failure_threshold|default(3) }}

          startupProbe:
            httpGet:
              path: {{ startup_path|default('/health') }}
              port: {{ port|default(8080) }}
            initialDelaySeconds: {{ startup_initial_delay|default(0) }}
            periodSeconds: {{ startup_period|default(10) }}
            timeoutSeconds: {{ startup_timeout|default(5) }}
            failureThreshold: {{ startup_failure_threshold|default(3) }}

  # Traffic configuration
  traffic:
    - percent: 100
      latestRevision: true

---
# Optional: IAM Policy for public access
{% if allow_unauthenticated %}
apiVersion: v1
kind: Policy
metadata:
  name: {{ service_name|default(agent_name|lower|replace('_', '-')) }}-public
spec:
  bindings:
    - role: roles/run.invoker
      members:
        - allUsers
{% endif %}
