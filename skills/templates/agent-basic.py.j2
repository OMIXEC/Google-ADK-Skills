# src/agent.py
"""{{ agent_name }} - {{ description }}

Generated by Claude ADK Skills
"""

from google.adk.agents import Agent
from google.adk.tools import FunctionTool
{% if tools %}
from tools.domain_tools import {{ tools|join(', ') }}
{% endif %}
{% if rag_enabled %}
from google.adk.tools.retrieval.vertex_ai_rag_retrieval import VertexAiRagRetrieval
from vertexai import rag
from config import RAG_CORPUS_NAME
{% endif %}

instruction = """
You are {{ persona_description }}.

**Role:** {{ role }}

**Communication Style:** {{ communication_style }}

**Behavior Guidelines:**
{% for guideline in behavior_guidelines %}
{{ loop.index }}. {{ guideline }}
{% endfor %}

{% if tools %}
**Tools Available:**
{% for tool in tools %}
- {{ tool }}: {{ tool_descriptions[tool] }}
{% endfor %}
{% endif %}

{% if domain_specific_instructions %}
**Domain-Specific Instructions:**
{{ domain_specific_instructions }}
{% endif %}
"""

{{ agent_name }} = Agent(
    name="{{ agent_name }}",
    model="{{ model }}",
    description="{{ description }}",
    instruction=instruction,
    tools=[
        {% if tools %}
        {% for tool in tools %}
        FunctionTool({{ tool }}),
        {% endfor %}
        {% endif %}
        {% if rag_enabled %}
        VertexAiRagRetrieval(
            name="search_knowledge",
            description="Search knowledge base for information",
            rag_resources=[
                rag.RagResource(rag_corpus=RAG_CORPUS_NAME)
            ],
            similarity_top_k={{ rag_top_k|default(10) }},
            vector_distance_threshold={{ rag_threshold|default(0.3) }},
        ),
        {% endif %}
    ],
)

# Export as root agent
root_agent = {{ agent_name }}
